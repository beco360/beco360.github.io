---
const navLinks = [
  { label: 'Servicios', href: '/#features' },
  { label: 'Productos', href: '/#productos' },
  { label: 'Portafolio', href: '/#portafolio' },
  { label: 'FAQs', href: '/faqs' },
]
---

<nav
  id="main-nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  aria-label="Navegación principal"
>
  <div class="max-w-6xl mx-auto px-6 md:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm" aria-label="Beco 360 — inicio">
        <img src="/assets/brand/logo-dark.svg" alt="Beco 360" class="h-9 w-auto" width="99" height="36" />
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-8" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link text-text-2 hover:text-text-1 text-sm font-medium transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop CTA -->
      <div class="hidden md:flex">
        <button
          type="button"
          class="inline-flex items-center justify-center gap-2 rounded-md px-5 py-2.5 font-semibold text-sm bg-copper text-surface hover:bg-copper-dark transition-all duration-200 active:scale-[0.97] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper cursor-pointer"
          data-cal-link="beco360/llamada-inicial"
          data-cal-config='{"layout":"month_view"}'
        >
          Agenda una llamada
        </button>
      </div>

      <!-- Mobile hamburger -->
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden flex items-center justify-center w-10 h-10 text-text-2 hover:text-text-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-md transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-drawer"
      >
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-drawer"
    class="fixed top-0 right-0 h-full w-4/5 max-w-sm bg-surface-2 border-l border-surface-3 transform translate-x-full transition-transform duration-300 ease-in-out z-40 flex flex-col"
    aria-hidden="true"
    inert
  >
    <div class="flex items-center justify-between px-6 h-16 border-b border-surface-3">
      <img src="/assets/brand/logo-dark.svg" alt="Beco 360" class="h-9 w-auto" width="99" height="36" />
      <button
        type="button"
        id="drawer-close-btn"
        class="flex items-center justify-center w-10 h-10 text-text-2 hover:text-text-1 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-md transition-colors"
        aria-label="Cerrar menú"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <ul class="flex flex-col gap-1 p-6" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-3 px-4 text-text-2 hover:text-text-1 hover:bg-surface-3 rounded-md text-base font-medium transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper mobile-nav-link"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="px-6 pb-6 mt-auto">
      <button
        type="button"
        class="w-full inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold text-sm bg-copper text-surface hover:bg-copper-dark transition-all duration-200 active:scale-[0.97] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper cursor-pointer"
        data-cal-link="beco360/llamada-inicial"
        data-cal-config='{"layout":"month_view"}'
      >
        Agenda una llamada
      </button>
    </div>
  </div>

  <!-- Backdrop -->
  <div
    id="drawer-backdrop"
    class="fixed inset-0 bg-surface/60 backdrop-blur-sm z-30 hidden"
    aria-hidden="true"
  ></div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  const btn = document.getElementById('mobile-menu-btn');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const closeBtn = document.getElementById('drawer-close-btn');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  // Scroll: transparent → blurred background
  window.addEventListener('scroll', updateNavSurface, { passive: true });

  const focusableSelectors = 'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])';

  function trapFocus(e: KeyboardEvent) {
    if (!drawer || e.key !== 'Tab') return;
    const focusable = Array.from(drawer.querySelectorAll<HTMLElement>(focusableSelectors));
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }

  function isDrawerOpen() {
    return btn?.getAttribute('aria-expanded') === 'true';
  }

  function openDrawer() {
    if (!drawer || !backdrop || !btn) return;
    drawer.classList.remove('translate-x-full');
    drawer.removeAttribute('inert');
    backdrop.classList.remove('hidden');
    btn.setAttribute('aria-expanded', 'true');
    drawer.setAttribute('aria-hidden', 'false');
    hamburgerIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', trapFocus);
    // Move focus into drawer
    const firstFocusable = drawer.querySelector<HTMLElement>(focusableSelectors);
    firstFocusable?.focus();
  }

  function closeDrawer() {
    if (!drawer || !backdrop || !btn) return;
    drawer.classList.add('translate-x-full');
    drawer.setAttribute('inert', '');
    backdrop.classList.add('hidden');
    btn.setAttribute('aria-expanded', 'false');
    drawer.setAttribute('aria-hidden', 'true');
    hamburgerIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    document.body.style.overflow = '';
    document.removeEventListener('keydown', trapFocus);
    btn.focus();
  }

  btn?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Close drawer on mobile nav link click
  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', closeDrawer);
  });

  // Escape key closes drawer — only when open
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isDrawerOpen()) closeDrawer();
  });

  // Compute nav scroll state on first paint (handles restored scroll / deep links)
  function updateNavSurface() {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add('bg-surface/90', 'backdrop-blur-md', 'border-b', 'border-surface-3');
    } else {
      nav.classList.remove('bg-surface/90', 'backdrop-blur-md', 'border-b', 'border-surface-3');
    }
  }
  updateNavSurface();
</script>
