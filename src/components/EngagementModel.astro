---
import CalButton from './CalButton.astro';

// Modelo de engagement forward-deployed: Diagnóstico → Construcción → Evolución
const fases = [
  {
    paso: '01',
    nombre: 'Diagnóstico',
    precio: 'COP $3.500.000',
    formato: 'Pago único · 1–2 semanas',
    descripcion:
      'Nos incrustamos en tu operación, mapeamos tus procesos y te entregamos un roadmap priorizado de qué construir y por dónde empezar.',
    bullets: [
      'Entrevistas + mapeo de tu operación',
      'Roadmap priorizado por retorno',
      'Es tuyo, lo contrates o no a Beco',
      'Se acredita si avanzas a construir',
    ],
    destacado: true,
  },
  {
    paso: '02',
    nombre: 'Construcción',
    precio: 'Desde $8.000.000',
    formato: 'Por proyecto · precio cerrado',
    descripcion:
      'Tomamos la oportunidad de mayor retorno del roadmap y la construimos: del prototipo a un sistema funcionando dentro de tu operación.',
    bullets: [
      'Precio cerrado según el alcance',
      'Primer prototipo en días',
      'Integrado a tus sistemas',
      'Trabajamos hombro a hombro contigo',
    ],
    destacado: false,
  },
  {
    paso: '03',
    nombre: 'Evolución',
    precio: 'Desde $2.500.000',
    formato: 'Mensual · opcional, sin permanencia',
    descripcion:
      'Una vez el sistema vive en producción, lo mantenemos, lo escalamos y construimos lo siguiente del roadmap. A tu ritmo.',
    bullets: [
      'Soporte y monitoreo del sistema',
      'Nuevas oportunidades del roadmap',
      'Mejoras continuas con IA',
      'Cancelas con 15 días de aviso',
    ],
    destacado: false,
  },
];
---

<section id="modelo" class="bg-surface-2" aria-labelledby="modelo-heading">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-24 md:py-32">

    <div class="max-w-2xl mb-14">
      <p class="eyebrow text-copper mb-4 reveal">Cómo trabajamos</p>
      <h2
        id="modelo-heading"
        class="font-display text-text-1 reveal"
        style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; line-height: 1.06; transition-delay: 60ms;"
      >
        Diagnóstico, construcción y <em>evolución</em>.
      </h2>
      <p class="text-text-2 mt-5 leading-relaxed reveal" style="transition-delay: 120ms;">
        Un camino claro para meterle IA a tu operación sin riesgo: primero entendemos dónde rinde,
        después lo construimos, y nos quedamos para que siga mejorando.
      </p>
    </div>

    <!-- Phase cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {fases.map((fase, i) => (
        <article
          class:list={['phase-card group reveal flex flex-col', fase.destacado && 'phase-card--featured']}
          style={`transition-delay: ${(i + 1) * 70}ms;`}
        >
          <div class="flex items-center justify-between mb-6">
            <span class="font-mono text-xs text-copper tracking-widest">{fase.paso}</span>
            {fase.destacado && (
              <span class="eyebrow text-copper" style="font-size: 0.625rem;">Empieza aquí</span>
            )}
          </div>

          <h3 class="text-text-1 text-lg font-semibold mb-1">{fase.nombre}</h3>
          <p class="text-text-3 text-xs font-mono mb-6">{fase.formato}</p>

          <div class="mb-6">
            <span
              class="font-display text-text-1"
              style="font-size: clamp(1.5rem, 2.6vw, 1.875rem); font-weight: 500; letter-spacing: -0.02em;"
            >
              {fase.precio}
            </span>
          </div>

          <p class="text-text-2 text-sm leading-relaxed mb-7">{fase.descripcion}</p>

          <ul class="space-y-3 mt-auto" role="list">
            {fase.bullets.map((b) => (
              <li class="flex items-start gap-2.5 text-text-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-copper shrink-0 mt-1" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 reveal" style="transition-delay: 320ms;">
      <CalButton size="lg" ariaLabel="Agenda mi llamada gratis con Beco 360">
        Agenda tu llamada gratis →
      </CalButton>
      <p class="text-text-3 text-xs mt-4">
        20 minutos · Sin compromiso · Definimos juntos por dónde empezar
      </p>
    </div>

  </div>
</section>

<style>
  .phase-card {
    position: relative;
    padding: 1.75rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-text-3) 16%, transparent);
    background: var(--color-surface);
    transition:
      border-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .phase-card:hover {
    border-color: color-mix(in srgb, var(--color-copper) 30%, transparent);
    transform: translateY(-3px);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-copper) 18%, transparent),
      0 18px 40px -16px rgba(0, 0, 0, 0.55);
  }

  /* Featured (entry) phase — subtle copper gradient hairline */
  .phase-card--featured {
    border: 1px solid transparent;
    background:
      linear-gradient(var(--color-surface), var(--color-surface)) padding-box,
      linear-gradient(
          160deg,
          color-mix(in srgb, var(--color-copper) 45%, transparent),
          color-mix(in srgb, var(--color-copper) 6%, transparent) 55%
        )
        border-box;
  }

  @media (prefers-reduced-motion: reduce) {
    .phase-card {
      transition: none;
    }
    .phase-card:hover {
      transform: none;
    }
  }
</style>
