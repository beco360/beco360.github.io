---
import Badge from './Badge.astro'

interface Props {
  nombre: string
  descripcion: string
  badge: 'active' | 'beta' | 'coming-soon'
  badgeText: string
  href?: string
}

const { nombre, descripcion, badge, badgeText, href = '#' } = Astro.props
---

<a
  href={href}
  target={href !== '#' ? '_blank' : undefined}
  rel={href !== '#' ? 'noopener noreferrer' : undefined}
  class="group relative flex flex-col rounded-xl border border-surface-3 bg-surface-2 p-8 transition-all duration-200 hover:-translate-y-1 hover:border-copper focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper"
  aria-label={`${nombre} — ${descripcion}`}
>
  <!-- "Ver proyecto" badge appears on hover -->
  <span
    class="absolute top-4 right-4 inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-copper/20 text-copper border border-copper/40 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
    aria-hidden="true"
  >
    Ver proyecto
  </span>

  <div class="mb-4">
    <Badge text={badgeText} variant={badge} />
  </div>

  <h3 class="text-text-1 text-xl font-bold mb-3">{nombre}</h3>
  <p class="text-text-2 text-sm leading-relaxed">{descripcion}</p>
</a>
