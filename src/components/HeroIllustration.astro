---
// Hero illustration — «IA dentro de tus herramientas».
// A copper core holds the Beco 360 mark: a 6-node hub (nh-hex) whose node ring
// rotates slowly (360° coverage) with a gently pulsing center. Around it, the
// 5 tools the business already uses (WhatsApp, Excel, CRM, Agenda, Factura)
// orbit in a pentagon, each wired to the core by a thread with data particles
// flowing IN — the AI orchestrating the tools that already exist.
//
// Entrance (JS, time-based): core fades/scales in, chips pop (easeOutBack),
// threads draw, particles flow. Ambient (CSS, no-preference only): glow
// breathes, hub rotates, center pulses, particles flow. reduce → static state.
const ICON = {
  whatsapp: '<path d="M128,32A96,96,0,0,0,44.89,176.07L32.42,213.46a8,8,0,0,0,10.12,10.12l37.39-12.47A96,96,0,1,0,128,32Zm24,152a80,80,0,0,1-80-80,32,32,0,0,1,32-32l16,32-12.32,18.47a48.19,48.19,0,0,0,25.85,25.85L152,136l32,16A32,32,0,0,1,152,184Z" opacity="0.2"/><path d="M187.58,144.84l-32-16a8,8,0,0,0-8,.5l-14.69,9.8a40.55,40.55,0,0,1-16-16l9.8-14.69a8,8,0,0,0,.5-8l-16-32A8,8,0,0,0,104,64a40,40,0,0,0-40,40,88.1,88.1,0,0,0,88,88,40,40,0,0,0,40-40A8,8,0,0,0,187.58,144.84ZM152,176a72.08,72.08,0,0,1-72-72A24,24,0,0,1,99.29,80.46l11.48,23L101,118a8,8,0,0,0-.73,7.51,56.47,56.47,0,0,0,30.15,30.15A8,8,0,0,0,138,155l14.62-9.74,23,11.48A24,24,0,0,1,152,176ZM128,24A104,104,0,0,0,36.18,176.88L24.83,210.93a16,16,0,0,0,20.24,20.24l34.05-11.35A104,104,0,1,0,128,24Zm0,192a87.87,87.87,0,0,1-44.06-11.81,8,8,0,0,0-6.54-.67L40,216,52.47,178.6a8,8,0,0,0-.66-6.54A88,88,0,1,1,128,216Z"/>',
  excel: '<path d="M152,80v96a8,8,0,0,1-8,8H40a8,8,0,0,1-8-8V80a8,8,0,0,1,8-8H144A8,8,0,0,1,152,80Z" opacity="0.2"/><path d="M200,24H72A16,16,0,0,0,56,40V64H40A16,16,0,0,0,24,80v96a16,16,0,0,0,16,16H56v24a16,16,0,0,0,16,16H200a16,16,0,0,0,16-16V40A16,16,0,0,0,200,24Zm-40,80h40v48H160Zm40-16H160V80a16,16,0,0,0-16-16V40h56ZM72,40h56V64H72ZM40,80H144v79.83c0,.06,0,.11,0,.17s0,.11,0,.17V176H40ZM72,192h56v24H72Zm72,24V192a16,16,0,0,0,16-16v-8h40v48ZM65.85,146.88,81.59,128,65.85,109.12a8,8,0,0,1,12.3-10.24L92,115.5l13.85-16.62a8,8,0,1,1,12.3,10.24L102.41,128l15.74,18.88a8,8,0,0,1-12.3,10.24L92,140.5,78.15,157.12a8,8,0,0,1-12.3-10.24Z"/>',
  address: '<path d="M208,32H64a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H208a8,8,0,0,0,8-8V40A8,8,0,0,0,208,32ZM136,144a32,32,0,1,1,32-32A32,32,0,0,1,136,144Z" opacity="0.2"/><path d="M83.19,174.4a8,8,0,0,0,11.21-1.6,52,52,0,0,1,83.2,0,8,8,0,1,0,12.8-9.6A67.88,67.88,0,0,0,163,141.51a40,40,0,1,0-53.94,0A67.88,67.88,0,0,0,81.6,163.2,8,8,0,0,0,83.19,174.4ZM112,112a24,24,0,1,1,24,24A24,24,0,0,1,112,112Zm96-88H64A16,16,0,0,0,48,40V64H32a8,8,0,0,0,0,16H48v40H32a8,8,0,0,0,0,16H48v40H32a8,8,0,0,0,0,16H48v24a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V40A16,16,0,0,0,208,24Zm0,192H64V40H208Z"/>',
  calendar: '<path d="M216,48V88H40V48a8,8,0,0,1,8-8H208A8,8,0,0,1,216,48Z" opacity="0.2"/><path d="M208,32H184V24a8,8,0,0,0-16,0v8H88V24a8,8,0,0,0-16,0v8H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32ZM72,48v8a8,8,0,0,0,16,0V48h80v8a8,8,0,0,0,16,0V48h24V80H48V48ZM208,208H48V96H208V208Zm-38.34-85.66a8,8,0,0,1,0,11.32l-48,48a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L116,164.69l42.34-42.35A8,8,0,0,1,169.66,122.34Z"/>',
  receipt: '<path d="M224,56V208l-32-16-32,16-32-16L96,208,64,192,32,208V56a8,8,0,0,1,8-8H216A8,8,0,0,1,224,56Z" opacity="0.2"/><path d="M72,104a8,8,0,0,1,8-8h96a8,8,0,0,1,0,16H80A8,8,0,0,1,72,104Zm8,40h96a8,8,0,0,0,0-16H80a8,8,0,0,0,0,16ZM232,56V208a8,8,0,0,1-11.58,7.15L192,200.94l-28.42,14.21a8,8,0,0,1-7.16,0L128,200.94,99.58,215.15a8,8,0,0,1-7.16,0L64,200.94,35.58,215.15A8,8,0,0,1,24,208V56A16,16,0,0,1,40,40H216A16,16,0,0,1,232,56Zm-16,0H40V195.06l20.42-10.22a8,8,0,0,1,7.16,0L96,199.06l28.42-14.22a8,8,0,0,1,7.16,0L160,199.06l28.42-14.22a8,8,0,0,1,7.16,0L216,195.06Z"/>',
};

// 5 tools in a pentagon around the core at (300,270).
const tools = [
  { icon: ICON.whatsapp, label: 'WhatsApp', cx: 300, cy: 70,  d: 'M300,102 L300,220' },
  { icon: ICON.excel,    label: 'Excel',    cx: 490, cy: 208, d: 'M459.6,217.9 L347.6,254.5' },
  { icon: ICON.receipt,  label: 'Factura',  cx: 418, cy: 432, d: 'M399.2,406.1 L329.4,310.5' },
  { icon: ICON.calendar, label: 'Agenda',   cx: 182, cy: 432, d: 'M200.8,406.1 L270.6,310.5' },
  { icon: ICON.address,  label: 'CRM',      cx: 110, cy: 208, d: 'M140.4,217.9 L252.4,254.5' },
];

// nh-hex hub nodes (pentagon of six, R=30) around the core center (300,270).
const hub = [ [300, 240], [326, 255], [326, 285], [300, 300], [274, 285], [274, 255] ];
---

<div class="hero-illus" data-hero-illus>
  <svg viewBox="0 0 600 540" fill="none" class="hero-svg" role="img"
       aria-label="Un núcleo de IA conectado 360° a las herramientas que ya usas: WhatsApp, Excel, CRM, Agenda y Factura.">
    <defs>
      <radialGradient id="heroGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#cc8354" stop-opacity="0.5" />
        <stop offset="55%" stop-color="#cc8354" stop-opacity="0.13" />
        <stop offset="100%" stop-color="#cc8354" stop-opacity="0" />
      </radialGradient>
    </defs>

    <g class="hero-glowwrap">
      <circle class="hero-glow" cx="300" cy="270" r="140" fill="url(#heroGlow)" />
    </g>

    <g class="hero-threads" stroke="#cc8354" stroke-width="1.3" stroke-opacity="0.5" fill="none" stroke-linecap="round">
      {tools.map((t) => <path class="hero-thread" d={t.d} />)}
    </g>

    <g class="hero-flow" fill="#ffd9b8">
      {tools.map((t, i) => <circle r="2.4" style={`offset-path:path('${t.d}');animation-delay:${i * 0.5}s`} />)}
      {tools.map((t, i) => <circle r="1.7" style={`offset-path:path('${t.d}');animation-delay:${i * 0.5 + 1.3}s`} />)}
    </g>

    <!-- AI core: Beco 360 hub (nh-hex) -->
    <g class="hero-corewrap">
      <g class="hero-core">
        <circle cx="300" cy="270" r="52" fill="#211c18" stroke="#cc8354" stroke-width="2" />
        <g class="hero-hub">
          <g stroke="#cc8354" stroke-width="2" stroke-linecap="round">
            {hub.map(([x, y]) => <line x1="300" y1="270" x2={x} y2={y} />)}
          </g>
          <g fill="#cc8354">
            {hub.map(([x, y]) => <circle cx={x} cy={y} r="4.5" />)}
          </g>
        </g>
        <circle cx="300" cy="270" r="9.5" fill="#211c18" stroke="#cc8354" stroke-width="2" />
        <circle class="hero-hubcore" cx="300" cy="270" r="2.8" fill="#ffd9b8" />
      </g>
    </g>

    <g class="hero-tools">
      {tools.map((t, i) => (
        <g class="hero-tool" data-idx={i}>
          <rect x={t.cx - 30} y={t.cy - 30} width="60" height="60" rx="16" fill="#1c1a18" stroke="#3a3632" stroke-width="1.5" />
          <svg x={t.cx - 16} y={t.cy - 16} width="32" height="32" viewBox="0 0 256 256" fill="#cc8354"><g set:html={t.icon} /></svg>
          <text class="hero-label" x={t.cx} y={t.cy + 46} text-anchor="middle">{t.label}</text>
        </g>
      ))}
    </g>
  </svg>
</div>

<style>
  .hero-illus { width: 100%; max-width: 34rem; margin-inline: auto; }
  .hero-svg { width: 100%; height: auto; display: block; }

  .hero-label {
    font-family: var(--font-jakarta), system-ui, sans-serif;
    font-size: 13px; font-weight: 600; letter-spacing: 0.01em;
    fill: var(--color-text-2, #b3ada6);
  }

  .hero-glow, .hero-core, .hero-tool, .hero-hub, .hero-hubcore {
    transform-box: fill-box; transform-origin: center;
  }

  /* initial / pre-JS state — resolved by the entrance driver */
  .hero-glowwrap { opacity: 0; }
  .hero-corewrap { opacity: 0; }
  .hero-core { transform: scale(0.5); }
  .hero-tool { opacity: 0; }
  .hero-thread { stroke-dasharray: 1; stroke-dashoffset: 1; }
  .hero-flow { opacity: 0; }

  /* ---- ambient life (only when motion is allowed) ---- */
  @media (prefers-reduced-motion: no-preference) {
    .hero-glow { animation: heroBreathe 4s ease-in-out infinite; }
    .hero-hub { animation: heroSpin 22s linear infinite; }
    .hero-hubcore { animation: heroPulse 3s ease-in-out infinite; }
    .hero-flow circle { animation: heroFlow 2.6s linear infinite; }
  }
  @keyframes heroBreathe { 0%, 100% { opacity: 0.8; transform: scale(1); } 50% { opacity: 1; transform: scale(1.07); } }
  @keyframes heroSpin { to { transform: rotate(360deg); } }
  @keyframes heroPulse { 0%, 100% { opacity: 0.65; transform: scale(1); } 50% { opacity: 1; transform: scale(1.5); } }
  @keyframes heroFlow { 0% { offset-distance: 0%; } 100% { offset-distance: 100%; } }

  @media (prefers-reduced-motion: reduce) {
    .hero-flow { display: none; }
  }
</style>

<script>
  function initHero(root: Element) {
    const clamp = (v: number) => Math.max(0, Math.min(1, v));
    const seg = (p: number, a: number, b: number) => clamp((p - a) / (b - a));
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
    const back = (t: number) => { const c1 = 1.70158, c3 = c1 + 1; return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2); };

    const glowwrap = root.querySelector<SVGGElement>('.hero-glowwrap');
    const corewrap = root.querySelector<SVGGElement>('.hero-corewrap');
    const core = root.querySelector<SVGGElement>('.hero-core');
    const flow = root.querySelector<SVGGElement>('.hero-flow');
    const chips = [...root.querySelectorAll<SVGGElement>('.hero-tool')];
    const threads = [...root.querySelectorAll<SVGPathElement>('.hero-thread')];

    threads.forEach((el) => {
      const L = el.getTotalLength();
      (el as any).__len = L;
      el.style.strokeDasharray = String(L);
    });

    function drive(p: number) {
      const coreOp = seg(p, 0, 0.3);
      if (glowwrap) glowwrap.style.opacity = String(coreOp);
      if (corewrap) corewrap.style.opacity = String(coreOp);
      if (core) core.style.transform = `scale(${0.5 + 0.5 * back(seg(p, 0.02, 0.36))})`;

      chips.forEach((el, i) => {
        const a = 0.24 + i * 0.07;
        el.style.opacity = String(seg(p, a, a + 0.16));
        el.style.transform = `scale(${Math.max(0, back(seg(p, a, a + 0.26)))})`;
      });

      threads.forEach((el, i) => {
        const t = easeOut(seg(p, 0.5 + i * 0.045, 0.8 + i * 0.045));
        el.style.strokeDashoffset = String((el as any).__len * (1 - t));
      });
      if (flow) flow.style.opacity = String(seg(p, 0.75, 1));
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      drive(1);
      return;
    }

    let started = false;
    function run() {
      if (started) return;
      started = true;
      const t0 = performance.now();
      const DUR = 1700;
      function frame(now: number) {
        const p = clamp((now - t0) / DUR);
        drive(p);
        if (p < 1) requestAnimationFrame(frame);
      }
      requestAnimationFrame(frame);
    }

    drive(0);
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { io.disconnect(); run(); } });
      }, { threshold: 0.25 });
      io.observe(root);
    } else {
      run();
    }
  }

  function initAll() {
    document.querySelectorAll('[data-hero-illus]').forEach(initHero);
  }
  if (document.readyState !== 'loading') initAll();
  else document.addEventListener('DOMContentLoaded', initAll);
</script>
