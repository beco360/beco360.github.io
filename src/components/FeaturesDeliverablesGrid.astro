---
const deliverables = [
  {
    id: '01',
    icon: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
    quote: '"Quiero que cuando alguien pida un presupuesto me llegue un WhatsApp"',
    title: 'Bot de cotización por WhatsApp',
    result: 'Califica leads, responde preguntas y agenda citas. Solo. 24/7. Sin contratar a nadie.',
  },
  {
    id: '02',
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
    quote: '"Quiero que la factura se genere sola cuando cierro una venta"',
    title: 'Facturación automática',
    result: 'Cierras la venta → la factura llega al cliente en segundos.',
  },
  {
    id: '03',
    icon: '<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>',
    quote: '"Quiero ver las ventas del mes sin abrir Excel"',
    title: 'Dashboard de KPIs en tiempo real',
    result: 'Ventas, top clientes y comparativo mensual. En una pantalla.',
  },
  {
    id: '04',
    icon: '<rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="m9 16 2 2 4-4"/>',
    quote: '"Quiero que mis clientes agenden solos"',
    title: 'Agenda online con confirmación automática',
    result: 'El cliente elige horario, paga si aplica. Tú recibes la confirmación.',
  },
  {
    id: '05',
    icon: '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
    quote: '"Quiero vender por mi web pero no sé cómo"',
    title: 'E-commerce con pasarela de pago',
    result: 'Catálogo + carrito + Wompi/PSE/Nequi. Sin plataformas de terceros.',
  },
  {
    id: '06',
    icon: '<path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/>',
    quote: '"Quiero saber cuándo me queda poco inventario"',
    title: 'Inventario con alertas automáticas',
    result: 'Stock bajo → WhatsApp al instante. Sin revisar nada.',
  },
];
---

<section id="features" class="bg-surface" aria-labelledby="features-heading">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-24 md:py-32">

    <div class="text-center mb-16">
      <p class="eyebrow text-copper mb-4">Lo que construimos</p>
      <h2
        id="features-heading"
        class="font-display text-text-1"
        style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; line-height: 1.08;"
      >
        Del problema de negocio<br class="hidden sm:block" /> a un sistema <em class="text-copper">funcionando</em>
      </h2>
      <p class="text-text-2 mt-4 max-w-xl mx-auto">
        Cuéntanos qué te quita tiempo. Le ponemos IA y lo dejamos funcionando dentro de tu operación.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="bento-grid">
      {deliverables.map((d) => (
        <article class="bento-card group" data-id={d.id}>
          <!-- Icon + counter -->
          <div class="flex items-start justify-between mb-6">
            <svg
              class="bento-icon"
              width="30"
              height="30"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              set:html={d.icon}
            />
            <span class="font-mono text-xs text-copper tracking-widest">{d.id}</span>
          </div>

          <!-- Quote (client voice) -->
          <p class="text-text-3 text-sm italic leading-relaxed mb-5 flex-1">
            {d.quote}
          </p>

          <!-- Deliverable title -->
          <h3 class="text-text-1 font-bold text-base leading-snug mb-2">
            {d.title}
          </h3>

          <!-- Result -->
          <p class="text-text-2 text-sm leading-relaxed mb-5">
            {d.result}
          </p>

          <!-- Badge -->
          <div class="flex items-center gap-1.5 mt-auto">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-copper shrink-0" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-mono text-[11px] text-text-3 tracking-wide">En producción · entregado</span>
          </div>
        </article>
      ))}
    </div>

    <p class="text-text-3 text-sm text-center mt-12">
      Estos son casos reales. En tu diagnóstico identificamos cuál es la oportunidad de mayor retorno para tu negocio.
    </p>

  </div>
</section>

<style>
  /* Bento asymmetric grid */
  .bento-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto;
    }

    /* 01 spans 2 cols */
    .bento-card:nth-child(1) { grid-column: span 2; }
    /* 04 spans 2 cols */
    .bento-card:nth-child(4) { grid-column: span 2; }
    /* 05 goes full first on its row — stays 1 col */
    /* 06 spans 2 cols */
    .bento-card:nth-child(6) { grid-column: span 2; }
  }

  /* Card base */
  .bento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-text-3) 16%, transparent);
    background: var(--color-surface-2);
    transition:
      border-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 400ms cubic-bezier(0.16, 1, 0.3, 1);
    min-height: 210px;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--color-copper) 28%, transparent);
    transform: translateY(-3px);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-copper) 16%, transparent),
      0 18px 40px -16px rgba(0, 0, 0, 0.55);
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-card {
      transition: none;
    }
    .bento-card:hover {
      transform: none;
    }
  }

  /* Large cards get a bigger quote */
  .bento-card:nth-child(1) p:nth-child(2),
  .bento-card:nth-child(4) p:nth-child(2),
  .bento-card:nth-child(6) p:nth-child(2) {
    font-size: 1rem;
  }

  .bento-icon {
    color: color-mix(in srgb, var(--color-copper) 80%, var(--color-text-1));
    transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .bento-card:hover .bento-icon {
    transform: translateY(-2px) scale(1.06);
  }
  @media (prefers-reduced-motion: reduce) {
    .bento-icon {
      transition: none;
    }
    .bento-card:hover .bento-icon {
      transform: none;
    }
  }
</style>
