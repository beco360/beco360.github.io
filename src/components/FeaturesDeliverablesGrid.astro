---
const deliverables = [
  {
    id: '01',
    pedido: '"Quiero que cuando alguien pida un presupuesto me llegue un WhatsApp"',
    titulo: 'Bot de cotización por WhatsApp',
    resultado:
      'Califica leads, responde preguntas y agenda citas. Solo. 24/7. Sin contratar a nadie.',
  },
  {
    id: '02',
    pedido: '"Quiero que la factura se genere sola cuando cierro una venta"',
    titulo: 'Facturación automática',
    resultado: 'Cierras la venta → la factura llega al cliente en segundos.',
  },
  {
    id: '03',
    pedido: '"Quiero ver las ventas del mes sin abrir Excel"',
    titulo: 'Dashboard de KPIs en tiempo real',
    resultado: 'Ventas, top clientes y comparativo mensual. En una pantalla.',
  },
  {
    id: '04',
    pedido: '"Quiero que mis clientes agenden solos"',
    titulo: 'Agenda online con confirmación automática',
    resultado: 'El cliente elige horario, paga si aplica. Vos recibís la confirmación.',
  },
  {
    id: '05',
    pedido: '"Quiero vender por mi web pero no sé cómo"',
    titulo: 'E-commerce con pasarela de pago',
    resultado: 'Catálogo + carrito + Wompi/PSE/Nequi. Sin plataformas de terceros.',
  },
  {
    id: '06',
    pedido: '"Quiero saber cuándo me queda poco inventario"',
    titulo: 'Inventario con alertas automáticas',
    resultado: 'Stock bajo → WhatsApp al instante. Sin revisar nada.',
  },
];
---

<section id="features" class="bg-surface" aria-labelledby="features-heading">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-24 md:py-32">

    <div class="text-center mb-16">
      <p class="eyebrow text-copper mb-4">Lo que construimos</p>
      <h2
        id="features-heading"
        class="font-display text-text-1"
        style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; line-height: 1.08;"
      >
        Del problema de negocio<br class="hidden sm:block" /> a un sistema <em class="text-copper">funcionando</em>
      </h2>
      <p class="text-text-2 mt-4 max-w-xl mx-auto">
        Nos cuentas el problema. Nosotros diagnosticamos, construimos y lo dejamos andando en tu operación.
      </p>
    </div>

    <!-- Bento grid -->
    <div class="bento-grid">
      {deliverables.map((d) => (
        <article class="bento-card group" data-id={d.id}>
          <!-- Counter -->
          <span class="font-mono text-xs text-copper tracking-widest mb-auto block">
            {d.id}
          </span>

          <!-- Quote (client voice) -->
          <p class="text-text-3 text-sm italic leading-relaxed mt-4 mb-5 flex-1">
            {d.pedido}
          </p>

          <!-- Deliverable title -->
          <h3 class="text-text-1 font-bold text-base leading-snug mb-2">
            {d.titulo}
          </h3>

          <!-- Result -->
          <p class="text-text-2 text-sm leading-relaxed mb-5">
            {d.resultado}
          </p>

          <!-- Badge -->
          <div class="flex items-center gap-1.5 mt-auto">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-copper shrink-0" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="font-mono text-[11px] text-text-3 tracking-wide">En producción · entregado</span>
          </div>
        </article>
      ))}
    </div>

    <p class="text-text-3 text-sm text-center mt-12">
      Estos son casos reales. En tu diagnóstico identificamos cuál es la oportunidad de mayor retorno para tu negocio.
    </p>

  </div>
</section>

<style>
  /* Bento asymmetric grid */
  .bento-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto;
    }

    /* 01 spans 2 cols */
    .bento-card:nth-child(1) { grid-column: span 2; }
    /* 04 spans 2 cols */
    .bento-card:nth-child(4) { grid-column: span 2; }
    /* 05 goes full first on its row — stays 1 col */
    /* 06 spans 2 cols */
    .bento-card:nth-child(6) { grid-column: span 2; }
  }

  /* Card base */
  .bento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border-radius: 0.75rem;
    border: 1px solid color-mix(in srgb, var(--color-text-3) 16%, transparent);
    background: var(--color-surface-2);
    transition:
      border-color 400ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 400ms cubic-bezier(0.16, 1, 0.3, 1);
    min-height: 210px;
  }

  .bento-card:hover {
    border-color: color-mix(in srgb, var(--color-copper) 28%, transparent);
    transform: translateY(-3px);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-copper) 16%, transparent),
      0 18px 40px -16px rgba(0, 0, 0, 0.55);
  }

  @media (prefers-reduced-motion: reduce) {
    .bento-card {
      transition: none;
    }
    .bento-card:hover {
      transform: none;
    }
  }

  /* Large cards get a bigger quote */
  .bento-card:nth-child(1) p:nth-child(2),
  .bento-card:nth-child(4) p:nth-child(2),
  .bento-card:nth-child(6) p:nth-child(2) {
    font-size: 1rem;
  }
</style>
