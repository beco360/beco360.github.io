---
// Opción A: Menú rediseñado — menos categorías, copy orientado a resultado
const categories = [
  {
    icon: '⚡',
    title: 'Automatizaciones',
    color: 'text-yellow-400',
    items: [
      'Leads de tu web directo a WhatsApp',
      'Bot que responde y agenda mientras dormís',
      'Factura que se genera sola al cerrar la venta',
      'Reporte semanal que llega solo a tu correo',
    ],
  },
  {
    icon: '🤖',
    title: 'AI aplicada al negocio',
    color: 'text-copper',
    items: [
      'Chatbot entrenado con tu catálogo y precios',
      'Resumen diario de todos tus correos',
      'Análisis automático de reseñas de clientes',
      'Transcripción y resumen de reuniones',
    ],
  },
  {
    icon: '🌐',
    title: 'Web que trabaja para vos',
    color: 'text-blue-400',
    items: [
      'Calculadora de precios interactiva',
      'Sección de testimonios con fotos reales',
      'Galería con filtros por categoría',
      'Rediseño de homepage con CTA claro',
    ],
  },
  {
    icon: '📊',
    title: 'Datos y control',
    color: 'text-green-400',
    items: [
      'Dashboard de ventas actualizado en tiempo real',
      'Inventario con alertas de stock bajo',
      'KPIs del mes sin abrir un Excel',
      'Cotizador automático para tu equipo de ventas',
    ],
  },
]
---

<section class="bg-surface" aria-labelledby="features-a-heading">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-24 md:py-32">

    <div class="text-center mb-16">
      <h2
        id="features-a-heading"
        class="text-text-1 font-bold"
        style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
      >
        ¿Qué puedes pedirle a Beco?
      </h2>
      <p class="text-text-2 mt-4 max-w-xl mx-auto">
        Descríbelo en una oración. Nosotros lo construimos, probamos y entregamos.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {categories.map((cat) => (
        <div class="rounded-xl border border-surface-3 bg-surface-2 p-7 hover:border-copper/30 transition-colors duration-200">
          <div class="flex items-center gap-3 mb-5">
            <span class="text-2xl" aria-hidden="true">{cat.icon}</span>
            <h3 class={`font-bold text-base ${cat.color}`}>{cat.title}</h3>
          </div>
          <ul class="space-y-3" role="list">
            {cat.items.map((item) => (
              <li class="flex items-start gap-2.5 text-text-2 text-sm">
                <span class="text-text-3 mt-0.5 shrink-0" aria-hidden="true">→</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="text-text-3 text-sm text-center mt-10">
      Estos son ejemplos. Si lo puedes describir en una oración, lo podemos construir.
    </p>

  </div>
</section>
