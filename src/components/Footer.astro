---
const currentYear = new Date().getFullYear()
---

<footer class="bg-surface border-t border-surface-3">
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
      <!-- Brand column -->
      <div class="col-span-1 md:col-span-1">
        <a href="/" class="inline-block focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm" aria-label="Beco 360 — inicio">
          <span class="text-text-1 text-xl">
            <span class="font-extrabold">Beco</span> 360
          </span>
        </a>
        <p class="mt-3 text-text-3 text-sm leading-relaxed max-w-xs">
          Construimos productos con AI y llevamos esa inteligencia a tu empresa.
        </p>
        <!-- Social links -->
        <div class="flex gap-4 mt-6">
          <a
            href="https://www.facebook.com/beco360"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-3 hover:text-copper transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm"
            aria-label="Beco 360 en Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/beco360"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-3 hover:text-copper transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm"
            aria-label="Beco 360 en Instagram"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation column -->
      <div>
        <h3 class="text-text-1 text-sm font-semibold uppercase tracking-wider mb-4">Navegación</h3>
        <ul class="space-y-3" role="list">
          <li><a href="/#features" class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm">Servicios</a></li>
          <li><a href="/#productos" class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm">Productos</a></li>
          <li><a href="/faqs" class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm">FAQs</a></li>
          <li><a href="/cultura" class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm">Cultura</a></li>
          <li><a href="/legal/terms" class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm">Términos</a></li>
          <li><a href="/legal/privacy" class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm">Privacidad</a></li>
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="text-text-1 text-sm font-semibold uppercase tracking-wider mb-4">Contacto</h3>
        <ul class="space-y-3" role="list">
          <li>
            <a
              href="mailto:team@beco360.com"
              class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm"
            >
              team@beco360.com
            </a>
          </li>
          <li>
            <a
              href="https://wa.me/573508108761"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-3 hover:text-text-1 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-copper rounded-sm"
            >
              WhatsApp: +57 350 810 8761
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-surface-3 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-text-3 text-xs">
        &copy; {currentYear} Beco 360. Todos los derechos reservados.
      </p>
      <p class="text-text-3 text-xs">
        Medellín, Colombia
      </p>
    </div>
  </div>
</footer>
