---
interface Props {
  id?: string
  bg?: 'surface' | 'surface-2'
  class?: string
  tag?: 'section' | 'div'
  labelledby?: string
}

const {
  id,
  bg = 'surface',
  class: className = '',
  tag: Tag = 'section',
  labelledby,
} = Astro.props

const bgClass = bg === 'surface-2' ? 'bg-surface-2' : 'bg-surface'
---

<Tag
  id={id}
  class={`${bgClass} ${className}`}
  aria-labelledby={labelledby}
>
  <div class="max-w-6xl mx-auto px-6 md:px-8 py-24">
    <slot />
  </div>
</Tag>
