---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import FeaturesMenuRedesign from '../components/FeaturesMenuRedesign.astro'
import FeaturesDeliverablesGrid from '../components/FeaturesDeliverablesGrid.astro'
---

<Layout
  title="Preview — Comparación de secciones"
  description="Página de comparación interna"
>
  <Nav />

  <main>
    <!-- Label A -->
    <div class="bg-yellow-500/10 border-b border-yellow-500/30 px-6 py-3 text-center">
      <p class="text-yellow-400 text-sm font-semibold tracking-wide uppercase">
        Opción A — Menú rediseñado por categorías
      </p>
    </div>
    <FeaturesMenuRedesign />

    <!-- Divider -->
    <div class="bg-copper/10 border-y border-copper/30 px-6 py-6 text-center">
      <p class="text-copper text-sm font-bold tracking-widest uppercase">↑ Opción A &nbsp;&nbsp;·&nbsp;&nbsp; Opción B ↓</p>
    </div>

    <!-- Label B -->
    <div class="bg-blue-500/10 border-b border-blue-500/30 px-6 py-3 text-center">
      <p class="text-blue-400 text-sm font-semibold tracking-wide uppercase">
        Opción B — Features como entregables con resultado de negocio
      </p>
    </div>
    <FeaturesDeliverablesGrid />
  </main>
</Layout>
