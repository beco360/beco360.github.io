---
import CalButton from '../components/CalButton.astro';
import EngagementModel from '../components/EngagementModel.astro';
import FaqSection from '../components/FaqSection.astro';
import FeaturesDeliverablesGrid from '../components/FeaturesDeliverablesGrid.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import Section from '../components/Section.astro';
import SocialProof from '../components/SocialProof.astro';
import Layout from '../layouts/Layout.astro';

const pasos = [
  {
    numero: '01',
    titulo: 'Diagnóstico',
    descripcion:
      'Nos metemos en tu operación 1–2 semanas y te entregamos un roadmap de qué automatizar y por dónde empezar.',
  },
  {
    numero: '02',
    titulo: 'Construcción',
    descripcion:
      'Tomamos la oportunidad de mayor retorno y la construimos hasta dejarla funcionando en tu negocio.',
  },
  {
    numero: '03',
    titulo: 'Evolución',
    descripcion:
      'Mantenemos el sistema vivo y construimos lo siguiente del roadmap. A tu ritmo, sin permanencia.',
  },
];

const stats = [
  { valor: '3+', label: 'empresas activas' },
  { valor: '20+', label: 'soluciones en producción' },
  { valor: 'Días', label: 'del diagnóstico al prototipo' },
  { valor: '100%', label: 'enfocados en tu resultado' },
];

const faqsHome = [
  {
    pregunta: '¿Qué es exactamente el diagnóstico?',
    respuesta:
      'Nos incrustamos 1–2 semanas en tu operación: entrevistamos a tu equipo, observamos cómo trabajan hoy y mapeamos tus sistemas. Salimos con un roadmap priorizado de qué automatizar o construir y por dónde empezar, con el retorno estimado. Es tuyo, lo contrates o no el resto a Beco.',
  },
  {
    pregunta: '¿Cuánto cuesta trabajar con Beco?',
    respuesta:
      'Toda relación arranca con un diagnóstico de precio fijo (COP $3,500,000), que se acredita si avanzas a construir. De ahí, la construcción se cotiza por proyecto cerrado según el alcance (desde COP $8,000,000), y la evolución es un mensual opcional. Te decimos el número exacto antes de empezar — sin sorpresas.',
  },
  {
    pregunta: '¿Necesito saber de tecnología para trabajar con Beco?',
    respuesta:
      'Para nada. Tú describes el problema de negocio en español normal — "se me va media mañana pasando pedidos a Excel" — y nosotros diagnosticamos y construimos la solución. Si algo no es claro, preguntamos antes de empezar.',
  },
  {
    pregunta: '¿Por qué pagar por un diagnóstico y no solo cotizar lo que pido?',
    respuesta:
      'Porque construir lo que pediste sin entender el problema casi siempre termina en software que no mueve la aguja. El diagnóstico asegura que invertimos en la oportunidad de mayor retorno primero. Y si avanzas a construir, se acredita — no lo pagas dos veces.',
  },
  {
    pregunta: '¿Puedo cancelar la evolución cuando quiera?',
    respuesta:
      'Sí, sin permanencia ni penalidad. La evolución continúa porque el sistema te sigue dando valor, no porque te ata un contrato. Avisas con 15 días de anticipación y cerramos el mes en curso.',
  },
];
---

<Layout
  title="Beco 360 — Consultoría de transformación con IA para PyMEs"
  description="Diagnosticamos dónde tu negocio pierde tiempo y plata, y construimos el sistema con IA que lo resuelve. Consultoría de tecnología forward-deployed para PyMEs colombianas."
>
  <Nav />

  <main id="main-content">
    <!-- HERO -->
    <section class="bg-surface" aria-labelledby="hero-heading">
      <div class="max-w-4xl mx-auto px-6 md:px-8 pt-40 pb-32 md:pt-48 md:pb-40 text-center">
        <h1
          id="hero-heading"
          class="text-text-1 font-extrabold leading-tight"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
        >
          Diagnosticamos tu negocio<br />y construimos lo que le falta.
        </h1>

        <p class="text-text-3 text-sm mt-4 font-mono">
          Consultoría de tecnología con IA · para PyMEs colombianas
        </p>

        <p class="text-text-2 text-xl max-w-2xl mx-auto mt-6 leading-relaxed">
          Nos metemos en tu operación, encontramos dónde pierdes tiempo y plata,<br />
          y construimos el sistema con IA que lo resuelve. En días, no meses.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
          <CalButton size="md" ariaLabel="Agenda mi llamada gratis con Beco 360">
            Agenda mi llamada gratis →
          </CalButton>
          <a
            href="#como-funciona"
            class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold text-sm border border-surface-3 text-text-2 hover:border-copper hover:text-copper transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper"
          >
            Ver cómo funciona ↓
          </a>
        </div>

        <!-- Microcopy de fricción -->
        <p class="text-text-3 text-xs mt-4">
          20 minutos · Sin compromiso · Sin tarjeta de crédito
        </p>
      </div>
    </section>

    <!-- PRUEBA SOCIAL — STATS -->
    <section class="bg-surface-2 border-y border-surface-3" aria-label="Estadísticas Beco 360">
      <div class="max-w-6xl mx-auto px-6 md:px-8 py-10">
        <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {stats.map((stat, i) => (
            <div class="reveal" style={`transition-delay: ${i * 80}ms;`}>
              <dt class="text-text-3 text-xs uppercase tracking-wider mb-1">{stat.label}</dt>
              <dd
                class="text-text-1 font-extrabold"
                style="font-size: clamp(1.75rem, 3vw, 2.25rem);"
              >
                {stat.valor}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <Section id="como-funciona" bg="surface" labelledby="como-funciona-heading">
      <div class="text-center mb-16">
        <h2
          id="como-funciona-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          Cómo trabajamos
        </h2>
        <p class="text-text-2 mt-4 max-w-xl mx-auto reveal" style="transition-delay: 80ms;">
          Del diagnóstico a un sistema funcionando — y evolucionando contigo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {pasos.map((paso, i) => (
          <div class="reveal" style={`transition-delay: ${(i + 1) * 80}ms;`}>
            <span class="text-copper font-extrabold block mb-4 text-5xl" aria-hidden="true">
              {paso.numero}
            </span>
            <h3 class="text-text-1 text-lg font-bold mb-2">{paso.titulo}</h3>
            <p class="text-text-2 text-sm leading-relaxed">{paso.descripcion}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- MODELO DE ENGAGEMENT -->
    <EngagementModel />

    <!-- FEATURES / EJEMPLOS -->
    <FeaturesDeliverablesGrid />

    <!-- SOCIAL PROOF -->
    <SocialProof />

    <!-- FAQs -->
    <FaqSection faqs={faqsHome} />

    <!-- CTA FINAL -->
    <Section bg="surface" labelledby="cta-final-heading">
      <div class="text-center max-w-2xl mx-auto">
        <h2
          id="cta-final-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          ¿Listo para saber qué automatizar primero?
        </h2>
        <p class="text-text-2 text-xl mt-4 reveal" style="transition-delay: 80ms;">
          Empieza con una llamada gratis de 20 minutos. Sin compromisos.
        </p>
        <div class="mt-10 reveal" style="transition-delay: 160ms;">
          <CalButton size="lg" ariaLabel="Agenda mi llamada gratis con Beco 360">
            Agenda mi llamada gratis →
          </CalButton>
          <p class="text-text-3 text-xs mt-3">20 minutos · Sin compromiso · Sin tarjeta de crédito</p>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Layout>
