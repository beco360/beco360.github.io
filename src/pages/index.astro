---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import Section from '../components/Section.astro'
import PlanCard from '../components/PlanCard.astro'
import ProductCard from '../components/ProductCard.astro'
import FeatureCategory from '../components/FeatureCategory.astro'
import PortfolioItem from '../components/PortfolioItem.astro'

import ingenierosBrand from '../../public/assets/clients/Ingenieros AB.webp'
import lsjBrand from '../../public/assets/clients/lsj.webp'

const planes = [
  {
    nombre: 'Mínimo',
    precio: 'COP $2,921,000',
    precioUSD: '~$885',
    features: ['2 features/mes (1 cada 15 días)'],
    syncs: '1 × 30 min',
    turnaround: '7 días hábiles',
    comunicacion: 'Async (WhatsApp)',
    popular: false,
  },
  {
    nombre: 'Estándar',
    precio: 'COP $5,800,000',
    precioUSD: '~$1,758',
    features: ['4 features/mes (1 por semana)'],
    syncs: '2 × 45 min',
    turnaround: '5 días hábiles',
    comunicacion: 'Async prioritario',
    popular: true,
  },
  {
    nombre: 'Pro',
    precio: 'COP $11,600,000',
    precioUSD: '~$3,515',
    features: ['8 features/mes (2 por semana)'],
    syncs: '4 × 60 min',
    turnaround: '3 días hábiles',
    comunicacion: 'Canal dedicado',
    popular: false,
  },
]

const featureCategories = [
  {
    icon: '🌐',
    title: 'Web y presencia',
    items: [
      'Rediseño de homepage',
      'Formulario a WhatsApp',
      'Calculadora de precios',
      'Galería con filtros',
      'Sección de testimonios',
      'FAQ interactivo',
    ],
  },
  {
    icon: '⚡',
    title: 'Automatizaciones',
    items: [
      'Bot WhatsApp 24/7',
      'Email de bienvenida automático',
      'Recordatorio de citas',
      'Factura automática',
      'Reporte semanal',
      'Alerta de inventario',
    ],
  },
  {
    icon: '🔌',
    title: 'Integraciones',
    items: [
      'Pasarela de pago (Wompi/PSE/Nequi)',
      'Sincronización con Google Sheets',
      'Conexión CRM',
      'WhatsApp Business API',
    ],
  },
  {
    icon: '🤖',
    title: 'AI y datos',
    items: [
      'Chatbot con conocimiento del negocio',
      'Resumen automático de correos',
      'Categorización de pedidos',
      'Análisis de reseñas de clientes',
      'Transcripción de llamadas',
    ],
  },
  {
    icon: '📊',
    title: 'Dashboards',
    items: [
      'Ventas del mes',
      'KPIs en tiempo real',
      'Comparativo mensual',
      'Top clientes',
    ],
  },
  {
    icon: '🛠️',
    title: 'Herramientas internas',
    items: [
      'Cotizador automático',
      'Inventario con alertas',
      'Generador de contratos PDF',
      'Registro de asistencia',
    ],
  },
  {
    icon: '🛒',
    title: 'E-commerce',
    items: [
      'Catálogo con filtros',
      'Cupones de descuento',
      'Seguimiento de pedidos',
      'Pasarela completa',
    ],
  },
]

const pasos = [
  {
    numero: '01',
    titulo: 'Agenda tu llamada',
    descripcion: 'Cuéntanos qué necesitas. Primera llamada gratis. Sin compromisos.',
  },
  {
    numero: '02',
    titulo: 'Pide tu feature',
    descripcion: 'Descríbela en un mensaje. Sin tecnicismos. Nosotros la construimos.',
  },
  {
    numero: '03',
    titulo: 'Recíbela lista',
    descripcion: 'En días, no semanas. Con AI trabajando de nuestro lado.',
  },
]
---

<Layout
  title="Beco 360 — Programador experimentado por 1 salario mínimo al mes"
  description="Contrata un programador experimentado por 1 salario mínimo al mes. Convierte tus ideas de negocio en realidad con AI. Sin prestaciones. Sin liquidaciones. Sin drama."
>
  <Nav />

  <main>
    <!-- HERO -->
    <section
      class="bg-surface"
      aria-labelledby="hero-heading"
    >
      <div class="max-w-4xl mx-auto px-6 md:px-8 pt-40 pb-32 md:pt-48 md:pb-40 text-center">
        <h1
          id="hero-heading"
          class="text-text-1 font-extrabold leading-tight reveal"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
        >
          Contrata un programador experimentado por 1 salario mínimo al mes.
        </h1>

        <p class="text-text-3 text-sm mt-4 font-mono reveal" style="transition-delay: 80ms;">
          COP $2,921,000/mes · el costo real de un empleado al salario mínimo
        </p>

        <p class="text-text-2 text-xl max-w-2xl mx-auto mt-6 leading-relaxed reveal" style="transition-delay: 160ms;">
          Convierte tus ideas de negocio en realidad con AI.<br />
          Sin prestaciones. Sin liquidaciones. Sin drama.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 reveal" style="transition-delay: 240ms;">
          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold text-sm bg-copper text-surface hover:bg-copper-dark transition-all duration-200 active:scale-[0.97] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper cursor-pointer"
            data-cal-link="beco360/llamada-inicial"
            data-cal-config='{"layout":"month_view"}'
          >
            Agenda una llamada
          </button>
          <a
            href="#como-funciona"
            class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold text-sm border border-surface-3 text-text-1 hover:border-copper hover:text-copper transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper"
          >
            Ver cómo funciona ↓
          </a>
        </div>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <Section id="como-funciona" bg="surface-2" labelledby="como-funciona-heading">
      <div class="text-center mb-16">
        <h2
          id="como-funciona-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          Cómo funciona
        </h2>
        <p class="text-text-2 mt-4 max-w-xl mx-auto reveal" style="transition-delay: 80ms;">
          Tres pasos para convertir tu próxima idea en realidad.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {pasos.map((paso, i) => (
          <div class="reveal" style={`transition-delay: ${(i + 1) * 80}ms;`}>
            <span class="text-copper font-extrabold block mb-4 text-5xl" aria-hidden="true">
              {paso.numero}
            </span>
            <h3 class="text-text-1 text-lg font-bold mb-2">{paso.titulo}</h3>
            <p class="text-text-2 text-sm leading-relaxed">{paso.descripcion}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- PLANES -->
    <Section id="planes" bg="surface" labelledby="planes-heading">
      <div class="text-center mb-16">
        <h2
          id="planes-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          Planes
        </h2>
        <p class="text-text-2 mt-4 max-w-xl mx-auto reveal" style="transition-delay: 80ms;">
          Capacidad mensual fija. Cancelas cuando quieras.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {planes.map((plan, i) => (
          <div class="reveal" style={`transition-delay: ${(i + 1) * 80}ms;`}>
            <PlanCard
              nombre={plan.nombre}
              precio={plan.precio}
              precioUSD={plan.precioUSD}
              features={plan.features}
              syncs={plan.syncs}
              turnaround={plan.turnaround}
              comunicacion={plan.comunicacion}
              popular={plan.popular}
            />
          </div>
        ))}
      </div>

      <p class="text-text-3 text-sm text-center mt-10 max-w-2xl mx-auto reveal" style="transition-delay: 400ms;">
        El plan Mínimo cuesta exactamente lo mismo que contratar un empleado al salario mínimo — incluyendo prestaciones, ARL y todo lo demás.
      </p>
    </Section>

    <!-- FEATURES / EJEMPLOS -->
    <Section id="features" bg="surface-2" labelledby="features-heading">
      <div class="text-center mb-16">
        <h2
          id="features-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          ¿Qué puedes pedirle a Beco?
        </h2>
        <p class="text-text-2 mt-4 max-w-2xl mx-auto reveal" style="transition-delay: 80ms;">
          Una feature es cualquier mejora descrita en una oración con un resultado claro.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {featureCategories.map((cat, i) => (
          <div class="reveal" style={`transition-delay: ${(i + 1) * 80}ms;`}>
            <FeatureCategory icon={cat.icon} title={cat.title} items={cat.items} />
          </div>
        ))}
      </div>
    </Section>

    <!-- PRODUCTOS -->
    <Section id="productos" bg="surface" labelledby="productos-heading">
      <div class="text-center mb-16">
        <h2
          id="productos-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          Lo que construimos
        </h2>
        <p class="text-text-2 mt-4 max-w-xl mx-auto reveal" style="transition-delay: 80ms;">
          Productos propios que demuestran que sabemos lo que hacemos.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="reveal" style="transition-delay: 80ms;">
          <ProductCard
            nombre="Alfil"
            descripcion="Plataforma de inteligencia política para Colombia, impulsada por AI y datos públicos."
            badge="active"
            badgeText="Activo"
            href="https://datos-co.com"
          />
        </div>
        <div class="reveal" style="transition-delay: 160ms;">
          <ProductCard
            nombre="Cotejo"
            descripcion="Conecta canchas, organizadores y jugadores de fútbol con gamificación."
            badge="beta"
            badgeText="Beta"
            href="https://cotejo.app"
          />
        </div>
      </div>
    </Section>

    <!-- PORTAFOLIO -->
    <Section id="portafolio" bg="surface-2" labelledby="portafolio-heading">
      <div class="text-center mb-16">
        <h2
          id="portafolio-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          Empresas que confían en Beco
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
        <div class="reveal" style="transition-delay: 80ms;">
          <PortfolioItem
            nombre="Ingenieros AB"
            sector="Ingeniería Civil"
            imageSrc={ingenierosBrand}
            imageAlt="Logo de Ingenieros AB — firma de ingeniería civil colombiana"
          />
        </div>
        <div class="reveal" style="transition-delay: 160ms;">
          <PortfolioItem
            nombre="LSJ"
            sector="E-commerce"
            imageSrc={lsjBrand}
            imageAlt="Logo de LSJ — tienda e-commerce colombiana"
          />
        </div>
        <div class="reveal" style="transition-delay: 240ms;">
          <PortfolioItem
            nombre="Real State"
            sector="Inmobiliaria"
          />
        </div>
      </div>
    </Section>

    <!-- CTA FINAL -->
    <Section bg="surface" labelledby="cta-final-heading">
      <div class="text-center max-w-2xl mx-auto">
        <h2
          id="cta-final-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          ¿Listo para convertir tu próxima idea en realidad?
        </h2>
        <p class="text-text-2 text-xl mt-4 reveal" style="transition-delay: 80ms;">
          Primera llamada gratis. Sin compromisos.
        </p>
        <div class="mt-10 reveal" style="transition-delay: 160ms;">
          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-md px-8 py-4 font-semibold text-base bg-copper text-surface hover:bg-copper-dark transition-all duration-200 active:scale-[0.97] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper cursor-pointer"
            data-cal-link="beco360/llamada-inicial"
            data-cal-config='{"layout":"month_view"}'
          >
            Agenda tu llamada ahora
          </button>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Layout>
