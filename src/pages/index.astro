---
import BeforeAfter from '../components/BeforeAfter.astro';
import CalButton from '../components/CalButton.astro';
import EngagementModel from '../components/EngagementModel.astro';
import FaqSection from '../components/FaqSection.astro';
import FeaturesDeliverablesGrid from '../components/FeaturesDeliverablesGrid.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import Section from '../components/Section.astro';
import SocialProof from '../components/SocialProof.astro';
import Layout from '../layouts/Layout.astro';

const differentiators = [
  {
    n: '01',
    title: 'Empezamos por tu proceso, no por la herramienta',
    desc: 'No llegamos con la IA de moda a ver dónde encaja. Primero entendemos tu operación y dónde de verdad te da retorno.',
  },
  {
    n: '02',
    title: 'La IA vive dentro de lo que ya usas',
    desc: 'La integramos a tus herramientas — WhatsApp, Excel, tu CRM — sin obligarte a cambiar de plataforma ni a aprender algo nuevo.',
  },
  {
    n: '03',
    title: 'Funcionando en días, no en meses',
    desc: 'Del diagnóstico a algo corriendo en producción en una fracción del tiempo de una agencia tradicional.',
  },
  {
    n: '04',
    title: 'Te hablamos de resultados, no de modelos',
    desc: 'Cada automatización se ata a una métrica: horas que recuperas, ventas, errores que desaparecen. No vendemos slides.',
  },
];

const stats = [
  { value: '3+', label: 'empresas activas' },
  { value: '20+', label: 'automatizaciones en producción' },
  { value: 'Días', label: 'del diagnóstico al prototipo' },
  { value: '100%', label: 'enfocados en tu resultado' },
];

const faqsHome = [
  {
    question: '¿Qué es exactamente el diagnóstico?',
    answer:
      'Nos incrustamos 1–2 semanas en tu operación: entrevistamos a tu equipo, observamos cómo trabajan hoy y mapeamos tus sistemas. Salimos con un roadmap priorizado de qué automatizar o construir y por dónde empezar, con el retorno estimado. Es tuyo, lo contrates o no el resto a Beco.',
  },
  {
    question: '¿Cuánto cuesta trabajar con Beco?',
    answer:
      'Depende de tu caso — por eso arrancamos con un diagnóstico. Ahí entendemos el alcance y te damos un número cerrado antes de construir nada, sin sorpresas. La construcción se cotiza por proyecto y la evolución es un mensual opcional. Lo conversamos en la llamada, sin compromiso.',
  },
  {
    question: '¿Necesito saber de tecnología para trabajar con Beco?',
    answer:
      'Para nada. Tú describes el problema de negocio en español normal — "se me va media mañana pasando pedidos a Excel" — y nosotros diagnosticamos y construimos la solución. Si algo no es claro, preguntamos antes de empezar.',
  },
  {
    question: '¿Por qué pagar por un diagnóstico y no solo cotizar lo que pido?',
    answer:
      'Porque construir lo que pediste sin entender el problema casi siempre termina en software que no mueve la aguja. El diagnóstico asegura que invertimos en la oportunidad de mayor retorno primero. Y si avanzas a construir, se acredita — no lo pagas dos veces.',
  },
  {
    question: '¿Puedo cancelar la evolución cuando quiera?',
    answer:
      'Sí, sin permanencia ni penalidad. La evolución continúa porque el sistema te sigue dando valor, no porque te ata un contrato. Avisas con 15 días de anticipación y cerramos el mes en curso.',
  },
];
---

<Layout
  title="Beco 360 — Consultoría de transformación con IA para PyMEs"
  description="Diagnosticamos dónde tu negocio pierde tiempo y plata, y construimos el sistema con IA que lo resuelve. Consultoría de tecnología forward-deployed para PyMEs colombianas."
>
  <Nav />

  <main id="main-content">
    <!-- HERO -->
    <section class="bg-surface relative overflow-hidden" aria-labelledby="hero-heading">
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="max-w-6xl mx-auto px-6 md:px-8 pt-36 pb-24 md:pt-44 md:pb-32 relative z-10">
        <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-12 lg:gap-20 items-center">

          <!-- Left: editorial copy -->
          <div>
            <h1
              id="hero-heading"
              class="font-display text-text-1 reveal"
              style="font-size: clamp(2.75rem, 5.6vw, 4.75rem); line-height: 1.03; font-weight: 500; transition-delay: 60ms;"
            >
              Del trabajo manual a una operación que corre con <em class="text-copper">IA</em>.
            </h1>

            <p class="text-text-2 text-lg max-w-xl mt-6 leading-[1.6] reveal" style="transition-delay: 140ms;">
              Encontramos qué tareas le roban horas a tu equipo, les ponemos IA dentro de las
              herramientas que ya usas, y las dejamos funcionando. En días, no meses.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mt-10 reveal" style="transition-delay: 220ms;">
              <CalButton size="lg" ariaLabel="Agenda mi llamada gratis con Beco 360">
                Agenda tu llamada gratis
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </CalButton>
              <a
                href="#model"
                class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-4 font-semibold text-sm border border-surface-3 text-text-2 hover:border-copper hover:text-copper transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper"
              >
                Cómo trabajamos
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
              </a>
            </div>

            <p class="text-text-3 text-xs mt-5 reveal" style="transition-delay: 300ms;">
              20 minutos · Sin compromiso · Sin tarjeta de crédito
            </p>
          </div>

          <!-- Right: AI illustration -->
          <div class="reveal flex items-center justify-center" style="transition-delay: 180ms;">
            <img
              src="/assets/illustrations/hero-ai.webp"
              alt="Los procesos de un negocio convergiendo en un núcleo impulsado por IA"
              width="900"
              height="900"
              class="w-full max-w-md h-auto select-none pointer-events-none"
              style="mask-image: radial-gradient(circle at 50% 48%, #000 42%, transparent 70%); -webkit-mask-image: radial-gradient(circle at 50% 48%, #000 42%, transparent 70%);"
              loading="eager"
              decoding="async"
            />
          </div>

        </div>
      </div>
    </section>

    <!-- SOCIAL PROOF — STATS -->
    <section class="bg-surface-2 border-y hairline" aria-label="Estadísticas Beco 360">
      <div class="max-w-6xl mx-auto px-6 md:px-8 py-12">
        <dl class="grid grid-cols-2 md:grid-cols-4">
          {stats.map((stat, i) => (
            <div
              class:list={['reveal py-4 md:py-2 px-2 md:px-10', i > 0 && 'md:border-l hairline']}
              style={`transition-delay: ${i * 70}ms;`}
            >
              <dd
                class="font-display text-text-1"
                style="font-size: clamp(2.25rem, 4vw, 3.25rem); font-weight: 500; line-height: 1;"
              >
                {stat.value}
              </dd>
              <dt class="eyebrow text-text-3 mt-3">{stat.label}</dt>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- WHY BECO -->
    <Section id="why" bg="surface" labelledby="why-heading">
      <div class="grid lg:grid-cols-[0.8fr_1.2fr] gap-12 lg:gap-20">
        <!-- Left: intro -->
        <div>
          <p class="eyebrow text-copper reveal">Por qué Beco</p>
          <h2
            id="why-heading"
            class="font-display text-text-1 mt-5 reveal"
            style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; line-height: 1.08; transition-delay: 60ms;"
          >
            No te vendemos IA. La ponemos a <em class="text-copper">resolver</em> tu problema.
          </h2>
          <p class="text-text-2 mt-6 max-w-md leading-relaxed reveal" style="transition-delay: 120ms;">
            Cuatro razones por las que la IA con Beco sí funciona — y no queda a medias.
          </p>
        </div>

        <!-- Right: editorial index -->
        <ul class="border-t hairline" role="list">
          {differentiators.map((d, i) => (
            <li
              class="grid grid-cols-[auto_1fr] gap-5 md:gap-8 py-7 border-b hairline reveal"
              style={`transition-delay: ${i * 70}ms;`}
            >
              <span class="font-mono text-sm text-copper pt-1 tabular-nums">{d.n}</span>
              <div>
                <h3 class="text-text-1 font-bold text-lg mb-1.5">{d.title}</h3>
                <p class="text-text-2 text-sm leading-relaxed max-w-xl">{d.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </Section>

    <!-- BEFORE / AFTER AI -->
    <BeforeAfter />

    <!-- ENGAGEMENT MODEL -->
    <EngagementModel />

    <!-- FEATURES / EXAMPLES -->
    <FeaturesDeliverablesGrid />

    <!-- SOCIAL PROOF -->
    <SocialProof />

    <!-- FAQs -->
    <FaqSection faqs={faqsHome} />

    <!-- FINAL CTA -->
    <Section bg="surface" labelledby="cta-final-heading">
      <div class="text-center max-w-2xl mx-auto">
        <h2
          id="cta-final-heading"
          class="font-display text-text-1 reveal"
          style="font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 500; line-height: 1.08;"
        >
          ¿Listo para saber qué <em class="text-copper">automatizar</em> primero?
        </h2>
        <p class="text-text-2 text-xl mt-5 reveal" style="transition-delay: 80ms;">
          Empieza con una llamada gratis de 20 minutos. Sin compromisos.
        </p>
        <div class="mt-10 reveal" style="transition-delay: 160ms;">
          <CalButton size="lg" ariaLabel="Agenda mi llamada gratis con Beco 360">
            Agenda mi llamada gratis
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </CalButton>
          <p class="text-text-3 text-xs mt-3">20 minutos · Sin compromiso · Sin tarjeta de crédito</p>
        </div>
      </div>
    </Section>
  </main>

  <Footer />

  <style>
    /* Soft copper light beam behind the hero — depth, not flat black */
    .hero-glow {
      position: absolute;
      top: -20%;
      right: -10%;
      width: 46rem;
      height: 46rem;
      max-width: 95vw;
      background: radial-gradient(
        circle,
        color-mix(in srgb, var(--color-copper) 16%, transparent),
        transparent 62%
      );
      filter: blur(30px);
      pointer-events: none;
      z-index: 0;
    }

    /* Hero process pipeline */
    .hero-pipeline {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .hero-step {
      display: grid;
      grid-template-columns: 2.25rem 1fr;
      gap: 1.1rem;
      padding: 1.3rem 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-text-3) 20%, transparent);
    }
    .hero-step-num {
      font-family: "Space Grotesk", ui-monospace, monospace;
      font-size: 1.05rem;
      font-weight: 500;
      color: var(--color-copper);
      font-variant-numeric: tabular-nums;
      line-height: 1.5;
    }
    .hero-step-title {
      color: var(--color-text-1);
      font-weight: 600;
      font-size: 1rem;
      margin-bottom: 0.2rem;
    }
    .hero-step-desc {
      color: var(--color-text-2);
      font-size: 0.875rem;
      line-height: 1.55;
      max-width: 22rem;
    }
  </style>
</Layout>
