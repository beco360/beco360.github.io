---
import CalButton from '../components/CalButton.astro';
import EngagementModel from '../components/EngagementModel.astro';
import FaqSection from '../components/FaqSection.astro';
import FeaturesDeliverablesGrid from '../components/FeaturesDeliverablesGrid.astro';
import Footer from '../components/Footer.astro';
import Nav from '../components/Nav.astro';
import Section from '../components/Section.astro';
import SocialProof from '../components/SocialProof.astro';
import Layout from '../layouts/Layout.astro';

const diferenciadores = [
  {
    n: '01',
    titulo: 'Diagnóstico antes que código',
    desc: 'Entendemos el problema de negocio antes de cotizar. Las agencias construyen lo que pediste; nosotros validamos que resuelva algo.',
  },
  {
    n: '02',
    titulo: 'Forward-deployed',
    desc: 'Nos incrustamos en tu operación; no entregamos un PDF desde afuera y desaparecemos. Construimos lo que recomendamos.',
  },
  {
    n: '03',
    titulo: 'Velocidad con IA',
    desc: 'Del diagnóstico a un sistema en producción en una fracción del tiempo de una agencia tradicional.',
  },
  {
    n: '04',
    titulo: 'Resultado medible',
    desc: 'Cada intervención se ata a una métrica: tiempo ahorrado, ventas, errores reducidos. No slides — software funcionando.',
  },
];

const stats = [
  { valor: '3+', label: 'empresas activas' },
  { valor: '20+', label: 'soluciones en producción' },
  { valor: 'Días', label: 'del diagnóstico al prototipo' },
  { valor: '100%', label: 'enfocados en tu resultado' },
];

const faqsHome = [
  {
    pregunta: '¿Qué es exactamente el diagnóstico?',
    respuesta:
      'Nos incrustamos 1–2 semanas en tu operación: entrevistamos a tu equipo, observamos cómo trabajan hoy y mapeamos tus sistemas. Salimos con un roadmap priorizado de qué automatizar o construir y por dónde empezar, con el retorno estimado. Es tuyo, lo contrates o no el resto a Beco.',
  },
  {
    pregunta: '¿Cuánto cuesta trabajar con Beco?',
    respuesta:
      'Toda relación arranca con un diagnóstico de precio fijo (COP $3,500,000), que se acredita si avanzas a construir. De ahí, la construcción se cotiza por proyecto cerrado según el alcance (desde COP $8,000,000), y la evolución es un mensual opcional. Te decimos el número exacto antes de empezar — sin sorpresas.',
  },
  {
    pregunta: '¿Necesito saber de tecnología para trabajar con Beco?',
    respuesta:
      'Para nada. Tú describes el problema de negocio en español normal — "se me va media mañana pasando pedidos a Excel" — y nosotros diagnosticamos y construimos la solución. Si algo no es claro, preguntamos antes de empezar.',
  },
  {
    pregunta: '¿Por qué pagar por un diagnóstico y no solo cotizar lo que pido?',
    respuesta:
      'Porque construir lo que pediste sin entender el problema casi siempre termina en software que no mueve la aguja. El diagnóstico asegura que invertimos en la oportunidad de mayor retorno primero. Y si avanzas a construir, se acredita — no lo pagas dos veces.',
  },
  {
    pregunta: '¿Puedo cancelar la evolución cuando quiera?',
    respuesta:
      'Sí, sin permanencia ni penalidad. La evolución continúa porque el sistema te sigue dando valor, no porque te ata un contrato. Avisas con 15 días de anticipación y cerramos el mes en curso.',
  },
];
---

<Layout
  title="Beco 360 — Consultoría de transformación con IA para PyMEs"
  description="Diagnosticamos dónde tu negocio pierde tiempo y plata, y construimos el sistema con IA que lo resuelve. Consultoría de tecnología forward-deployed para PyMEs colombianas."
>
  <Nav />

  <main id="main-content">
    <!-- HERO -->
    <section class="bg-surface relative overflow-hidden" aria-labelledby="hero-heading">
      <div class="hero-glow" aria-hidden="true"></div>

      <div class="max-w-6xl mx-auto px-6 md:px-8 pt-36 pb-24 md:pt-44 md:pb-32 relative z-10">
        <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-12 lg:gap-20 items-center">

          <!-- Left: editorial copy -->
          <div>
            <p class="eyebrow text-copper reveal">Consultoría de tecnología con IA · PyMEs</p>

            <h1
              id="hero-heading"
              class="font-display text-text-1 mt-6 reveal"
              style="font-size: clamp(2.75rem, 5.6vw, 4.75rem); line-height: 1.03; font-weight: 400; transition-delay: 60ms;"
            >
              Diagnosticamos tu negocio y <em class="text-copper">construimos</em> lo que le falta.
            </h1>

            <p class="text-text-2 text-lg md:text-xl max-w-xl mt-7 leading-relaxed reveal" style="transition-delay: 140ms;">
              Nos metemos en tu operación, encontramos dónde pierdes tiempo y plata, y construimos
              el sistema con IA que lo resuelve. En días, no meses.
            </p>

            <div class="flex flex-col sm:flex-row gap-4 mt-10 reveal" style="transition-delay: 220ms;">
              <CalButton size="lg" ariaLabel="Agenda mi llamada gratis con Beco 360">
                Agenda tu llamada gratis →
              </CalButton>
              <a
                href="#modelo"
                class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-4 font-semibold text-sm border border-surface-3 text-text-2 hover:border-copper hover:text-copper transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper"
              >
                Cómo trabajamos ↓
              </a>
            </div>

            <p class="text-text-3 text-xs mt-5 reveal" style="transition-delay: 300ms;">
              20 minutos · Sin compromiso · Sin tarjeta de crédito
            </p>
          </div>

          <!-- Right: process pipeline -->
          <div class="reveal" style="transition-delay: 180ms;">
            <p class="eyebrow text-text-3 mb-7">El recorrido</p>
            <ol class="hero-pipeline" role="list">
              <li class="hero-step">
                <span class="hero-step-num">01</span>
                <div>
                  <p class="hero-step-title">Diagnóstico</p>
                  <p class="hero-step-desc">Entramos a tu operación y mapeamos dónde está el mayor retorno.</p>
                </div>
              </li>
              <li class="hero-step">
                <span class="hero-step-num">02</span>
                <div>
                  <p class="hero-step-title">Construcción</p>
                  <p class="hero-step-desc">Construimos la solución y la dejamos funcionando en producción.</p>
                </div>
              </li>
              <li class="hero-step">
                <span class="hero-step-num">03</span>
                <div>
                  <p class="hero-step-title">Evolución</p>
                  <p class="hero-step-desc">La mantenemos, la escalamos y seguimos el roadmap contigo.</p>
                </div>
              </li>
            </ol>
          </div>

        </div>
      </div>
    </section>

    <!-- PRUEBA SOCIAL — STATS -->
    <section class="bg-surface-2 border-y hairline" aria-label="Estadísticas Beco 360">
      <div class="max-w-6xl mx-auto px-6 md:px-8 py-12">
        <dl class="grid grid-cols-2 md:grid-cols-4">
          {stats.map((stat, i) => (
            <div
              class:list={['reveal py-4 md:py-2 px-2 md:px-10', i > 0 && 'md:border-l hairline']}
              style={`transition-delay: ${i * 70}ms;`}
            >
              <dd
                class="font-display text-text-1"
                style="font-size: clamp(2.25rem, 4vw, 3.25rem); font-weight: 400; line-height: 1;"
              >
                {stat.valor}
              </dd>
              <dt class="eyebrow text-text-3 mt-3">{stat.label}</dt>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- POR QUÉ BECO -->
    <Section id="por-que" bg="surface" labelledby="porque-heading">
      <div class="grid lg:grid-cols-[0.8fr_1.2fr] gap-12 lg:gap-20">
        <!-- Left: intro -->
        <div>
          <p class="eyebrow text-copper reveal">Por qué Beco</p>
          <h2
            id="porque-heading"
            class="font-display text-text-1 mt-5 reveal"
            style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 400; line-height: 1.08; transition-delay: 60ms;"
          >
            No vendemos horas. <em class="text-copper">Resolvemos</em> el problema.
          </h2>
          <p class="text-text-2 mt-6 max-w-md leading-relaxed reveal" style="transition-delay: 120ms;">
            Cuatro cosas que nos separan de una agencia tradicional o un freelance.
          </p>
        </div>

        <!-- Right: editorial index -->
        <ul class="border-t hairline" role="list">
          {diferenciadores.map((d, i) => (
            <li
              class="grid grid-cols-[auto_1fr] gap-5 md:gap-8 py-7 border-b hairline reveal"
              style={`transition-delay: ${i * 70}ms;`}
            >
              <span class="font-mono text-sm text-copper pt-1 tabular-nums">{d.n}</span>
              <div>
                <h3 class="text-text-1 font-bold text-lg mb-1.5">{d.titulo}</h3>
                <p class="text-text-2 text-sm leading-relaxed max-w-xl">{d.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </Section>

    <!-- MODELO DE ENGAGEMENT -->
    <EngagementModel />

    <!-- FEATURES / EJEMPLOS -->
    <FeaturesDeliverablesGrid />

    <!-- SOCIAL PROOF -->
    <SocialProof />

    <!-- FAQs -->
    <FaqSection faqs={faqsHome} />

    <!-- CTA FINAL -->
    <Section bg="surface" labelledby="cta-final-heading">
      <div class="text-center max-w-2xl mx-auto">
        <h2
          id="cta-final-heading"
          class="font-display text-text-1 reveal"
          style="font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 400; line-height: 1.08;"
        >
          ¿Listo para saber qué <em class="text-copper">automatizar</em> primero?
        </h2>
        <p class="text-text-2 text-xl mt-5 reveal" style="transition-delay: 80ms;">
          Empieza con una llamada gratis de 20 minutos. Sin compromisos.
        </p>
        <div class="mt-10 reveal" style="transition-delay: 160ms;">
          <CalButton size="lg" ariaLabel="Agenda mi llamada gratis con Beco 360">
            Agenda mi llamada gratis →
          </CalButton>
          <p class="text-text-3 text-xs mt-3">20 minutos · Sin compromiso · Sin tarjeta de crédito</p>
        </div>
      </div>
    </Section>
  </main>

  <Footer />

  <style>
    /* Soft copper light beam behind the hero — depth, not flat black */
    .hero-glow {
      position: absolute;
      top: -20%;
      right: -10%;
      width: 46rem;
      height: 46rem;
      max-width: 95vw;
      background: radial-gradient(
        circle,
        color-mix(in srgb, var(--color-copper) 16%, transparent),
        transparent 62%
      );
      filter: blur(30px);
      pointer-events: none;
      z-index: 0;
    }

    /* Hero process pipeline */
    .hero-pipeline {
      list-style: none;
      margin: 0;
      padding: 0;
    }
    .hero-step {
      position: relative;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 1.25rem;
      padding-bottom: 2rem;
    }
    .hero-step:last-child {
      padding-bottom: 0;
    }
    .hero-step:not(:last-child)::before {
      content: "";
      position: absolute;
      left: 1.4rem;
      top: 2.9rem;
      bottom: 0;
      width: 1px;
      background: linear-gradient(
        to bottom,
        color-mix(in srgb, var(--color-copper) 50%, transparent),
        transparent
      );
    }
    .hero-step-num {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2.8rem;
      height: 2.8rem;
      border-radius: 0.75rem;
      border: 1px solid color-mix(in srgb, var(--color-copper) 35%, transparent);
      background: color-mix(in srgb, var(--color-copper) 8%, var(--color-surface));
      font-family: ui-monospace, "Cascadia Code", monospace;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--color-copper);
      flex-shrink: 0;
    }
    .hero-step-title {
      color: var(--color-text-1);
      font-weight: 700;
      font-size: 1.05rem;
      margin-bottom: 0.2rem;
    }
    .hero-step-desc {
      color: var(--color-text-2);
      font-size: 0.875rem;
      line-height: 1.55;
      max-width: 22rem;
    }
  </style>
</Layout>
