---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import Section from '../components/Section.astro'
import PricingSlider from '../components/PricingSlider.astro'
import FeaturesDeliverablesGrid from '../components/FeaturesDeliverablesGrid.astro'
import SocialProof from '../components/SocialProof.astro'
import FaqSection from '../components/FaqSection.astro'



const pasos = [
  {
    numero: '01',
    titulo: 'Agenda tu llamada',
    descripcion: 'Cuéntanos qué necesitas. Primera llamada gratis. Sin compromisos.',
  },
  {
    numero: '02',
    titulo: 'Pide tu feature',
    descripcion: 'Descríbela en un mensaje. Sin tecnicismos. Nosotros la construimos.',
  },
  {
    numero: '03',
    titulo: 'Recíbela lista',
    descripcion: 'En días, no semanas. Con AI trabajando de nuestro lado.',
  },
]

const stats = [
  { valor: '3+', label: 'empresas activas' },
  { valor: '20+', label: 'features entregadas' },
  { valor: '5 días', label: 'tiempo promedio de entrega' },
  { valor: '100%', label: 'satisfacción garantizada' },
]

const faqsHome = [
  {
    pregunta: '¿Cuánto tarda en entregarse una feature?',
    respuesta: 'El plan Mínimo garantiza entrega en 7 días hábiles, el Estándar en 5 y el Pro en 3. En la práctica, features simples (formulario, sección nueva, integración) salen antes. Siempre te avisamos antes de empezar si hay algo que pueda tardar más.',
  },
  {
    pregunta: '¿Puedo cancelar cuando quiera?',
    respuesta: 'Sí, sin penalidad ni período mínimo. Avisas con 15 días de anticipación y cerramos el mes en curso. No hay contratos de permanencia.',
  },
  {
    pregunta: '¿Necesito saber de tecnología para trabajar con Beco?',
    respuesta: 'Para nada. Describes lo que quieres en español normal — "quiero que cuando alguien llene el formulario me llegue un WhatsApp" — y nosotros lo traducimos a código. Si algo no es claro, preguntamos antes de empezar.',
  },
  {
    pregunta: '¿Qué pasa si el resultado no me gusta?',
    respuesta: 'Hacemos ajustes hasta que quede como lo imaginaste. Si describiste la feature y el resultado no cumple con esa descripción, la corregimos sin costo. El objetivo es que cada feature cierre como entregada y aprobada por ti.',
  },
  {
    pregunta: '¿Por qué es tan barato comparado con una agencia o un freelancer?',
    respuesta: 'Porque trabajamos con AI como parte del equipo, lo que multiplica la velocidad de ejecución. Además, el modelo de retainer nos da previsibilidad — sabemos cuánta capacidad tenemos cada mes y podemos planificar sin sorpresas. No es barato: es eficiente.',
  },
]
---

<Layout
  title="Beco 360 — Programador experimentado por 1 salario mínimo al mes"
  description="Contrata un programador experimentado por 1 salario mínimo al mes. Convierte tus ideas de negocio en realidad con AI. Sin prestaciones. Sin liquidaciones. Sin drama."
>
  <Nav />

  <main id="main-content">
    <!-- HERO -->
    <section class="bg-surface" aria-labelledby="hero-heading">
      <div class="max-w-4xl mx-auto px-6 md:px-8 pt-40 pb-32 md:pt-48 md:pb-40 text-center">
        <h1
          id="hero-heading"
          class="text-text-1 font-extrabold leading-tight reveal"
          style="font-size: clamp(2.5rem, 6vw, 4.5rem);"
        >
          Contrata un programador experimentado<br />por 1 salario mínimo al mes.
        </h1>

        <p class="text-text-3 text-sm mt-4 font-mono reveal" style="transition-delay: 80ms;">
          COP $2,921,000/mes · el costo real de un empleado al salario mínimo
        </p>

        <p class="text-text-2 text-xl max-w-2xl mx-auto mt-6 leading-relaxed reveal" style="transition-delay: 160ms;">
          Convierte tus ideas de negocio en realidad con AI.<br />
          Sin prestaciones. Sin liquidaciones. Sin drama.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10 reveal" style="transition-delay: 240ms;">
          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold text-sm bg-copper text-surface hover:bg-copper-dark transition-all duration-200 active:scale-[0.97] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper cursor-pointer"
            data-cal-link="beco360/llamada-inicial"
            data-cal-config='{"layout":"month_view"}'
            aria-label="Agenda mi llamada gratis con Beco 360"
          >
            Agenda mi llamada gratis →
          </button>
          <a
            href="#como-funciona"
            class="inline-flex items-center justify-center gap-2 rounded-md px-6 py-3 font-semibold text-sm border border-surface-3 text-text-2 hover:border-copper hover:text-copper transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper"
          >
            Ver cómo funciona ↓
          </a>
        </div>

        <!-- Microcopy de fricción -->
        <p class="text-text-3 text-xs mt-4 reveal" style="transition-delay: 320ms;">
          20 minutos · Sin compromiso · Sin tarjeta de crédito
        </p>
      </div>
    </section>

    <!-- PRUEBA SOCIAL — STATS -->
    <section class="bg-surface-2 border-y border-surface-3" aria-label="Estadísticas Beco 360">
      <div class="max-w-6xl mx-auto px-6 md:px-8 py-10">
        <dl class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {stats.map((stat, i) => (
            <div class="reveal" style={`transition-delay: ${i * 80}ms;`}>
              <dt class="text-text-3 text-xs uppercase tracking-wider mb-1">{stat.label}</dt>
              <dd
                class="text-text-1 font-extrabold"
                style="font-size: clamp(1.75rem, 3vw, 2.25rem);"
              >
                {stat.valor}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </section>

    <!-- CÓMO FUNCIONA -->
    <Section id="como-funciona" bg="surface" labelledby="como-funciona-heading">
      <div class="text-center mb-16">
        <h2
          id="como-funciona-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          Cómo funciona
        </h2>
        <p class="text-text-2 mt-4 max-w-xl mx-auto reveal" style="transition-delay: 80ms;">
          Tres pasos para convertir tu próxima idea en realidad.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {pasos.map((paso, i) => (
          <div class="reveal" style={`transition-delay: ${(i + 1) * 80}ms;`}>
            <span class="text-copper font-extrabold block mb-4 text-5xl" aria-hidden="true">
              {paso.numero}
            </span>
            <h3 class="text-text-1 text-lg font-bold mb-2">{paso.titulo}</h3>
            <p class="text-text-2 text-sm leading-relaxed">{paso.descripcion}</p>
          </div>
        ))}
      </div>
    </Section>

    <!-- PLANES -->
    <PricingSlider />

    <!-- FEATURES / EJEMPLOS -->
    <FeaturesDeliverablesGrid />

    <!-- SOCIAL PROOF -->
    <SocialProof />

    <!-- FAQs -->
    <FaqSection faqs={faqsHome} />

    <!-- CTA FINAL -->
    <Section bg="surface" labelledby="cta-final-heading">
      <div class="text-center max-w-2xl mx-auto">
        <h2
          id="cta-final-heading"
          class="text-text-1 font-bold reveal"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);"
        >
          ¿Listo para convertir tu próxima idea en realidad?
        </h2>
        <p class="text-text-2 text-xl mt-4 reveal" style="transition-delay: 80ms;">
          Primera llamada gratis. Sin compromisos.
        </p>
        <div class="mt-10 reveal" style="transition-delay: 160ms;">
          <button
            type="button"
            class="inline-flex items-center justify-center gap-2 rounded-md px-8 py-4 font-semibold text-base bg-copper text-surface hover:bg-copper-dark transition-all duration-200 active:scale-[0.97] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-copper cursor-pointer"
            data-cal-link="beco360/llamada-inicial"
            data-cal-config='{"layout":"month_view"}'
            aria-label="Agenda mi llamada gratis con Beco 360"
          >
            Agenda mi llamada gratis →
          </button>
          <p class="text-text-3 text-xs mt-3">20 minutos · Sin compromiso · Sin tarjeta de crédito</p>
        </div>
      </div>
    </Section>
  </main>

  <Footer />
</Layout>
